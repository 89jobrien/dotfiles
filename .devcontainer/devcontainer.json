{
  "name": "dotfiles-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "postCreateCommand": "mise trust; mise install || true; ALLOW_DIRECT_DOTFILES_INSTALL=1 ./install.sh --dot-only",
  "remoteEnv": {
    "PATH": "/usr/local/bin:/home/vscode/.local/bin:/home/vscode/.local/share/mise/shims:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/usr/bin/zsh" }
        },
        "editor.formatOnSave": true,
        "[shellscript]": {
          "editor.defaultFormatter": "foxundermoon.shell-format"
        }
      },
      "extensions": [
        "tamasfe.even-better-toml",
        "ms-vscode.makefile-tools",
        "skellock.just",
        "mads-hartmann.bash-ide-vscode",
        "foxundermoon.shell-format",
        "timonwong.shellcheck",
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
