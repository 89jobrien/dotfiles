# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Sensitive files (if you add them)
**/*.secret
**/*.key
**/*.pem

# Shell history files (contain sensitive data)
**/.zsh_history
**/.bash_history
**/fish_variables

# 1Password config (may contain sensitive paths)
**/op/

# API keys and tokens
**/raycast/ai/
**/raycast/extensions/*/secrets.json
secrets/*.env
!secrets/*.example
!secrets/*.sops
secrets/.env.json
!secrets/.env.sops.json
.env
.env.local
mise.local.toml
.venv/

# Machine-local app state (do not commit)
/raycast/
/mcpm/
/vector/
!vector/.config/
!vector/.config/**

# Local build/runtime artifacts
/.venv/
/.cache/
/.ctx/

# Local bootstrap overrides (mutable layer)
config/stow-packages.local.txt
config/apt-packages.local.txt
scripts/post-bootstrap.local.sh

# Python bytecode
__pycache__/
*.pyc

# Nix build output symlinks
result
result-*

# Rust toolz crate build artifacts
toolz/target/

# Local Zed artifacts
zed/.config/zed/prompts/
zed/.config/zed/settings_backup.json

# Claude Code local artifacts
.claude/review-loop.log

# Audit logs (accumulated redaction scan results)
.logs/*.jsonl
.logs/*.log

# Beads and local markdown
.beads/
*.local.md

# Tailscale device exports (contain network topology)
tailscale/backups/
tailscale/ssh-config.generated
