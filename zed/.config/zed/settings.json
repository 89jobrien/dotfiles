{
  "project_panel": {
    "dock": "right"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "theme": "Catppuccin Macchiato - No Italics",
  "vim_mode": false,
  "format_on_save": "on",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "tab_size": 2,
  "hard_tabs": false,
  "context_servers": {
    "mcp-server-tavily": {
      "enabled": true,
      "settings": {
        "tavily_api_key": "$TAVILY_API_KEY"
      }
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "$CONTEXT7_API_KEY"
      }
    },
    "personal": {
      "command": "/Users/rentamac/.local/bin/personal-mcp",
      "args": [],
      "env": {
        "MCP_CTX_DIR": "/Users/rentamac/.ctx",
        "MCP_ENV_FILE": "/Users/rentamac/.config/dev-bootstrap/secrets.env",
        "BAML_LOG": "info",
        "BOUNDARY_MAX_LOG_CHUNK_CHARS": "3000"
      }
    }
  }
}
