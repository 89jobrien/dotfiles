# MCP Context Server API Keys
# Copy to ~/.config/dev-bootstrap/secrets.env and fill in your values

# Tavily Search API (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Context7 Documentation API (https://context7.ai)
CONTEXT7_API_KEY=your_context7_api_key_here

# MCP Server Configuration
MCP_CTX_DIR="${HOME}/.ctx"
MCP_ENV_FILE="${HOME}/.config/dev-bootstrap/secrets.env"
BAML_LOG=info
BOUNDARY_MAX_LOG_CHUNK_CHARS=3000

# OpenAI API (https://platform.openai.com/api-keys)
# Also available via 1Password: op://cli/OpenAI/credential
OPENAI_API_KEY=your_openai_api_key_here
