#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${ROOT_DIR}/scripts/lib/cmd.sh"
"${ROOT_DIR}/scripts/secrets/check-no-plaintext.sh"
if has_cmd pj; then
  if ! pj secret scan --staged; then
    echo "warning: pj secret scan flagged potential issues (see above)" >&2
    echo "         the primary check (check-no-plaintext.sh) passed — continuing" >&2
  fi
fi

# Redaction audit — scan staged text files, log findings to .logs/redact-audit.jsonl
# Never blocks; pass --verbose to see findings in terminal
if has_cmd obfsck; then
  "${ROOT_DIR}/scripts/redact-audit.sh" --hook pre-commit --staged
fi
