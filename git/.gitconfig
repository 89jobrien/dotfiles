[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[user]
	name = Joesph O'Brien
	email = 98370624+89jobrien@users.noreply.github.com

[core]
	editor = vim
	autocrlf = input
	hooksPath = /Users/rentamac/.config/git/hooks

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true
	default = current

[fetch]
	prune = true

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate --all
	last = log -1 HEAD
	unstage = reset HEAD --

[color]
	ui = auto
[coderabbit]
	machineId = cli/35d6eb1759d74bd48409c39e2eb4802c
[credential "https://github.com"]
	helper = !/Users/rentamac/.nix-profile/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/Users/rentamac/.nix-profile/bin/gh auth git-credential
